{
  "name": "firefile_launcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "fil-reset": "node -e \"const fs=require('fs'),p=require('path').join(require('os').homedir(),'.minecraft');fs.rmSync(p,{recursive:true,force:true});console.log('Cleared',p);\" && npx tauri dev"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
